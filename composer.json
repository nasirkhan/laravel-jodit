{
    "name": "nasirkhan/laravel-jodit",
    "description": "Jodit WYSIWYG editor integration for Laravel — works with Blade, Blade Components, and Livewire",
    "keywords": [
        "laravel",
        "jodit",
        "wysiwyg",
        "editor",
        "blade",
        "livewire",
        "rich-text"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Nasir Khan Saikat",
            "email": "nasir8891@gmail.com",
            "homepage": "https://github.com/nasirkhan",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/nasirkhan/laravel-jodit",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/view": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0"
    },
    "suggest": {
        "intervention/image-laravel": "Required for image resize and crop operations (^1.5)"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nasirkhan\\LaravelJodit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nasirkhan\\LaravelJodit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nasirkhan\\LaravelJodit\\JoditServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true
    }
}
